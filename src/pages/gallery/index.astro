---
import { Icon } from "astro-icon/components";
import GalleryBrowser from "@/components/pages/gallery/GalleryBrowser.svelte";
import { galleryConfig, siteConfig } from "@/config";
import {
	createManagedPublicAlbum,
	galleryManagedSeed,
} from "@/config/galleryManagedSeed";
import I18nKey from "@/i18n/i18nKey";
import { i18n } from "@/i18n/translation";
import MainGridLayout from "@/layouts/MainGridLayout.astro";
import type { PublicGalleryAlbum } from "@/types/galleryAdmin";
import { getAlbumCover, scanAlbumPhotos } from "@/utils/gallery-utils";

if (!siteConfig.pages.gallery) {
	return Astro.redirect("/404/");
}

const title = i18n(I18nKey.gallery);
const description = i18n(I18nKey.galleryDescription);
const staticAlbums: PublicGalleryAlbum[] = galleryConfig.albums.map((album) => {
	const urls = scanAlbumPhotos(album.id);
	const photos = urls.map((photo) => ({
		key: photo,
		url: photo,
		name: photo.split("/").pop() || photo,
		size: 0,
	}));
	return {
		id: album.id,
		sourceDir: `gallery/${album.id}`,
		name: album.name,
		description: album.description,
		date: album.date,
		location: album.location,
		tags: album.tags || [],
		cover: "",
		photoOrder: urls,
		photos,
		photoCount: photos.length,
		coverUrl: getAlbumCover(album, urls),
	};
});
const managedFallbackAlbums: PublicGalleryAlbum[] = galleryManagedSeed.albums
	.filter(
		(album) => !staticAlbums.some((candidate) => candidate.id === album.id),
	)
	.map(createManagedPublicAlbum);
const initialAlbums: PublicGalleryAlbum[] = [
	...staticAlbums,
	...managedFallbackAlbums,
];
const staticAlbumIds = galleryConfig.albums.map((album) => album.id);
const managedAlbumIds = galleryManagedSeed.albums.map((album) => album.id);
---

<MainGridLayout title={title} description={description}>
	<section class="gallery-page card-base" aria-labelledby="gallery-page-title">
		<header class="gallery-heading">
			<div class="gallery-icon" aria-hidden="true">
				<Icon is:inline name="material-symbols:photo-library" />
			</div>
			<div>
				<h1 id="gallery-page-title">{title}</h1>
				{description && <p>{description}</p>}
			</div>
		</header>

		<GalleryBrowser client:load {initialAlbums} {staticAlbumIds} {managedAlbumIds} />
	</section>
</MainGridLayout>

<style>
	.gallery-page {
		width: 100%;
		padding: 1.4rem;
	}

	.gallery-heading {
		display: flex;
		align-items: flex-start;
		gap: 0.85rem;
		margin-bottom: 1rem;
	}

	.gallery-icon {
		display: grid;
		place-items: center;
		width: 2.35rem;
		height: 2.35rem;
		border-radius: 0.5rem;
		background: var(--primary);
		color: white;
		font-size: 1.3rem;
		flex: none;
	}

	.gallery-heading h1 {
		margin: 0;
		font-size: 1.55rem;
		font-weight: 800;
	}

	.gallery-heading p {
		margin: 0.25rem 0 0;
		font-size: 0.88rem;
		opacity: 0.62;
	}

	@media (max-width: 560px) {
		.gallery-page {
			padding: 1rem;
		}
	}
</style>
