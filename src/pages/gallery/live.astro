---
import GalleryAlbumRuntime from "@/components/pages/gallery/GalleryAlbumRuntime.svelte";
import { galleryConfig, siteConfig } from "@/config";
import MainGridLayout from "@/layouts/MainGridLayout.astro";

if (!siteConfig.pages.gallery) {
	return Astro.redirect("/404/");
}
---

<MainGridLayout title="相册" description="">
	<GalleryAlbumRuntime client:load columnWidth={galleryConfig.columnWidth || 240} />
</MainGridLayout>
