---
import { Icon } from "astro-icon/components";
import KatexManager from "@/components/features/KatexManager.astro";
import Navbar from "@/components/layout/Navbar.astro";
import WriteManager from "@/components/pages/write/WriteManager.svelte";
import Layout from "@/layouts/Layout.astro";
import "@/styles/expressive-code.css";
import "@/styles/markdown.css";

const title = "写作管理";
const description = "在站内创建、编辑、预览并提交 Firefly 文章。";
---

<Layout title={title} description={description}>
	<KatexManager slot="head" />

	<div
		id="top-row"
		class="z-50 pointer-events-none relative transition-all duration-700 mx-auto h-18 fixed top-0 left-0 right-0 z-80 w-full xl:w-[92vw] max-w-(--page-width) px-0 md:px-4"
	>
		<div id="navbar-wrapper" class="pointer-events-auto transition-all">
			<Navbar />
		</div>
	</div>

	<main class="write-page-shell">
		<section class="write-hero">
			<div class="write-hero-icon">
				<Icon is:inline name="material-symbols:edit-square-outline" />
			</div>
			<div>
				<h1 class="write-hero-title">{title}</h1>
				<p class="write-hero-description">{description}</p>
			</div>
		</section>

		<WriteManager client:only="svelte" />
	</main>
</Layout>

<style>
	.write-page-shell {
		position: relative;
		z-index: 30;
		width: min(96vw, calc(var(--page-width) * 1rem + 14rem));
		margin: 5.7rem auto 2rem;
		padding: 0 0.5rem;
	}

	.write-hero {
		display: flex;
		align-items: center;
		gap: 1rem;
		margin-bottom: 1.15rem;
		padding: 1.15rem 1.2rem;
		border-radius: var(--radius-large);
		border: 1px solid var(--line-divider);
		background: color-mix(in oklab, var(--card-bg) 90%, transparent);
		backdrop-filter: blur(12px);
	}

	.write-hero-icon {
		display: grid;
		place-items: center;
		width: 3rem;
		height: 3rem;
		border-radius: 1rem;
		background: var(--primary);
		color: white;
		font-size: 1.35rem;
		font-weight: 700;
		flex: none;
	}

	.write-hero-icon :global(svg) {
		width: 1.45rem;
		height: 1.45rem;
	}

	:global(.dark) .write-hero-icon {
		color: rgb(0 0 0 / 0.82);
	}

	.write-hero-title {
		margin: 0;
		font-size: clamp(1.6rem, 2vw, 2.2rem);
		font-weight: 800;
		line-height: 1.1;
	}

	.write-hero-description {
		margin: 0.4rem 0 0;
		font-size: 0.95rem;
		line-height: 1.7;
		color: rgb(20 20 24 / 0.56);
	}

	:global(.dark) .write-hero-description {
		color: rgb(255 255 255 / 0.54);
	}

	@media (max-width: 768px) {
		.write-page-shell {
			width: min(100vw, calc(var(--page-width) * 1rem + 2rem));
			margin-top: 5.3rem;
			padding: 0 0.35rem;
		}

		.write-hero {
			align-items: flex-start;
			padding: 1rem;
		}
	}
</style>
