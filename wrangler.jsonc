{
	"name": "firefly-blog",
	"main": "./worker/index.ts",
	"compatibility_date": "2025-01-01",
	"compatibility_flags": ["nodejs_compat"],
	"assets": {
		"directory": "./dist",
		"binding": "ASSETS",
		"run_worker_first": ["/api/*"]
	},
	"vars": {
		"IMAGEBED_BASE_URL": "https://img.casto.top",
		"GITHUB_ADMIN_LOGIN": "SteveGuo1726",
		"GITHUB_REPO": "SteveGuo1726/Firefly"
	}
}
